	void lock_pairs(void)
	{
	    for (int i = 0; i < pair_count; i++)
	    {
	        bool skip = false;
	        
	        
	        for (int j = 0; j < pair_count; j++)
	        {
	            if (locked[i][j])
	            {   
	                skip = true; 
	                break;
	            }
	        }
	        if (skip)
	            continue;
	
	        locked[pairs[i].winner][pairs[i].loser] = true;     
	    }
	     return;
	}
	
